NODE_ENV=testing
PORT=5002

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=bloggers_platform_test

IS_USER_AUTOMATICALLY_CONFIRMED=true
IS_SWAGGER_ENABLED=false
INCLUDE_TESTING_MODULE=true
DB_AUTOSYNC=true

ACCESS_TOKEN_SECRET=test_access_secret_mock
REFRESH_TOKEN_SECRET=test_refresh_secret_mock
ACCESS_TOKEN_EXPIRE_IN=10m
REFRESH_TOKEN_EXPIRE_IN=20m

BLOGS_MAX_POSTS_COUNT_BEFORE_MODERATION=2
PAYMENTS_SUBSCRIPTION_PRICE=1
USERS_REMOVE_UNCONFIRMED_USERS_SCHEDULER_INTERVAL_IN_MINUTES=1
REMOVE_UNCONFIRMED_USERS_AFTER_INTERVAL_IN_HOURS=1