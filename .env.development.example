NODE_ENV=development
PORT=5001

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=bloggers_platform_dev

IS_USER_AUTOMATICALLY_CONFIRMED=true
IS_SWAGGER_ENABLED=true
INCLUDE_TESTING_MODULE=true
DB_AUTOSYNC=false

ACCESS_TOKEN_SECRET=dev_access_secret_mock
REFRESH_TOKEN_SECRET=dev_refresh_secret_mock
ACCESS_TOKEN_EXPIRE_IN=50m
REFRESH_TOKEN_EXPIRE_IN=60m

BLOGS_MAX_POSTS_COUNT_BEFORE_MODERATION=10
PAYMENTS_SUBSCRIPTION_PRICE=5
USERS_REMOVE_UNCONFIRMED_USERS_SCHEDULER_INTERVAL_IN_MINUTES=30
REMOVE_UNCONFIRMED_USERS_AFTER_INTERVAL_IN_HOURS=5